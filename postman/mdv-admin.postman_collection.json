{
  "info": {
    "name": "MdV Admin - Supabase API",
    "description": "Collection per testare le API REST di Supabase per il progetto MdV Admin (Via del Vangelo)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://ixfsowqvlfdqwpkzdyye.supabase.co/rest/v1",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "YOUR_SUPABASE_ANON_KEY",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "apikey",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{apiKey}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Gospel Daily",
      "item": [
        {
          "name": "GET - Lista paginata",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Prefer",
                "value": "count=exact"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/gospel_daily?select=*,gospel:gospels(*),comment_sections(*)&order=date.desc&limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["gospel_daily"],
              "query": [
                { "key": "select", "value": "*,gospel:gospels(*),comment_sections(*)" },
                { "key": "order", "value": "date.desc" },
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "GET - Singolo per ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/gospel_daily?id=eq.1&select=*,gospel:gospels(*),comment_sections(*),media(*)",
              "host": ["{{baseUrl}}"],
              "path": ["gospel_daily"],
              "query": [
                { "key": "id", "value": "eq.1" },
                { "key": "select", "value": "*,gospel:gospels(*),comment_sections(*),media(*)" }
              ]
            }
          }
        },
        {
          "name": "GET - Per data",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/gospel_daily?date=eq.2025-12-10&select=*,gospel:gospels(*),comment_sections(*),media(*)",
              "host": ["{{baseUrl}}"],
              "path": ["gospel_daily"],
              "query": [
                { "key": "date", "value": "eq.2025-12-10" },
                { "key": "select", "value": "*,gospel:gospels(*),comment_sections(*),media(*)" }
              ]
            }
          }
        },
        {
          "name": "GET - Ricerca per santi",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/gospel_daily?saints=ilike.*natale*&select=*",
              "host": ["{{baseUrl}}"],
              "path": ["gospel_daily"],
              "query": [
                { "key": "saints", "value": "ilike.*natale*" },
                { "key": "select", "value": "*" }
              ]
            }
          }
        },
        {
          "name": "POST - Crea nuovo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Prefer",
                "value": "return=representation"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-12-25\",\n  \"gospel_id\": 1,\n  \"saints\": \"Natale del Signore\",\n  \"is_published\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/gospel_daily",
              "host": ["{{baseUrl}}"],
              "path": ["gospel_daily"]
            }
          }
        },
        {
          "name": "PATCH - Aggiorna",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Prefer",
                "value": "return=representation"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saints\": \"Santo Stefano\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/gospel_daily?id=eq.1",
              "host": ["{{baseUrl}}"],
              "path": ["gospel_daily"],
              "query": [
                { "key": "id", "value": "eq.1" }
              ]
            }
          }
        },
        {
          "name": "DELETE - Elimina",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/gospel_daily?id=eq.9999",
              "host": ["{{baseUrl}}"],
              "path": ["gospel_daily"],
              "query": [
                { "key": "id", "value": "eq.9999" }
              ]
            }
          }
        }
      ]
    },
